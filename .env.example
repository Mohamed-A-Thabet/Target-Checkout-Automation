# Target Bot Environment Variables Template
# Copy this file to '.env' and fill in your actual values before running.

# Gmail configuration for capturing Target OTP codes
EMAIL=your-email@gmail.com
EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Oxylabs proxy credentials (if using Oxylabs New York proxy)
OXY_USER=your-oxylabs-username
OXY_PASS=your-oxylabs-password
PROXY_HOST=pr.oxylabs.io
PROXY_PORT=7777
